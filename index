;\n            startActivity(newGameIntent);\n            finish();\n        });\n\n        ImageButton menuButton = findViewById(R.id.menuButton);\n\n        menuButton.setOnClickListener(v -> {\n            // Create popup menu here\n            PopupMenu popupMenu = new PopupMenu(this, v);\n            popupMenu.getMenuInflater().inflate(R.menu.menu, popupMenu.getMenu());\n\n            // Enable/disable draw and resign depending on gameOver\n            popupMenu.getMenu().findItem(R.id.action_draw).setEnabled(!gameOver);\n            popupMenu.getMenu().findItem(R.id.action_resign).setEnabled(!gameOver);\n\n            // Set click listener for menu items\n            popupMenu.setOnMenuItemClickListener(item -> {\n                //gets id of click\n                int id = item.getItemId();\n//checks which one matches and does the right function\n                if (awaitingPromotion) return true; // ignore clicks during promotion\n\n                // After game over  only restart is allowed\n                if (gameOver && id != R.id.action_restart) return true;\n\n                if (id == R.id.action_restart) {\n                    confirmRestart();\n                    return true;\n                }\n\n                if (id == R.id.action_draw) {\n                    offerDraw();\n                    return true;\n                }\n\n                if (id == R.id.action_resign) {\n                    confirmResign();\n                    return true;\n                }\n\n                return false;\n            });\n\n            popupMenu.show(); // finally show it\n        });\n\n\n    ","comment":""},"to":{"v":"-","ret":"void","n":"initClocks","p":"minutes","ctor":false,"body":"\n//convert time to millisecond\n        whiteTimeMs = minutes * 60 * 1000L;\n        blackTimeMs = minutes * 60 * 1000L;\n\n        tvWhiteClock = findViewById(R.id.tvWhiteClock);\n        tvBlackClock = findViewById(R.id.tvBlackClock);\n//connect back the time\n        updateClockText(tvWhiteClock, whiteTimeMs);\n        updateClockText(tvBlackClock, blackTimeMs);\n\n        createTimers();\n    ","comment":""}},{"from":{"v":"-","ret":"void","n":"confirmRestart","p":"","ctor":false,"body":"\n        //warning message\n        new AlertDialog.Builder(this)\n                .setTitle(\"Restart Game?\")\n                .setMessage(\"The current game will be lost.\")\n                .setPositiveButton(\"Restart\", (d, w) -> restartGame())\n                .setNegativeButton(\"Cancel\", null)\n                .show();\n    ","comment":""},"to":{"v":"-","ret":"void","n":"restartGame","p":"","ctor":false,"body":"\n        stopTimers();\n//change back colour from handle game over\n        GridLayout chessBoard = findViewById(R.id.chessBoard);\n        chessBoard.setAlpha(1f);\n        chessBoard.setEnabled(true);\n//change back  the function checks to false\n        gameState = new GameState();\n        gameOver = false;\n        awaitingPromotion = false;\n//resets clock\n        initClocks(gameTimeMinutes);\n        whiteTimer.start(); // White starts\n//clear the banner\n        gameOverBanner.setVisibility(View.GONE);\n//clear highlights and reset board\n        clearAllHighlights();\n        clearCheckHighlight();\n        updateClockStyles();\n        renderBoard();\n    ","comment":""}},{"from":{"v":"-","ret":"void","n":"createChessBoard","p":"","ctor":false,"body":"\n        GridLayout chessBoard = findViewById(R.id.chessBoard);\n\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n                //builds square and allows stacking\n                FrameLayout square = new FrameLayout(this);\n\n                GridLayout.LayoutParams params = new GridLayout.LayoutParams();\n                params.width = 0;\n                params.height = 0;\n                //keeps ratio\n                params.rowSpec = GridLayout.spec(row, 1f);\n                params.columnSpec = GridLayout.spec(col, 1f);\n\n                square.setLayoutParams(params);\n                //sets the colour even/odd\n                boolean isWhite = (row + col) % 2 == 0;\n                square.setBackgroundColor(\n                        isWhite\n                                ? Color.parseColor(\"#F0D9B5\")\n                                : Color.parseColor(\"#B58863\")\n                );\n// gives tags to connect UI to code\n                square.setTag(new SquareTag(row, col));\n                //triggers function onSquareClicked\n                square.setOnClickListener(this::onSquareClicked);\n\n                squareViews[row][col] = square;   //  store reference\n                chessBoard.addView(square);//adds them\n            }\n        }\n\n        renderBoard(); //  draw pieces\n    ","comment":""},"to":{"v":"-","ret":"void","n":"renderBoard","p":"","ctor":false,"body":"\n\n        clearAllHighlights();\n//cleans all pieces from last game\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n                squareViews[row][col].removeAllViews();\n            }\n        }\n        //places the pieces\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n//checks if a piece needs to go there\n                Piece piece = board().getPiece(new Position(col, row));\n                if (piece == null) continue;\n//places the right piece on the board\n                ImageView pieceView = new ImageView(this);\n                pieceView.setImageResource(getPieceDrawable(piece));\n                pieceView.setScaleType(ImageView.ScaleType.CENTER_INSIDE);\n                //adds piece\n                squareViews[row][col].addView(pieceView);\n            }\n        }\n    ","comment":""}},{"from":{"v":"-","ret":"void","n":"renderBoard","p":"","ctor":false,"body":"\n\n        clearAllHighlights();\n//cleans all pieces from last game\n        for (int row = 0; row < 8; row++) {\n    