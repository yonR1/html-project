lse,"body":"\r\n        if (this == o) return true;\r\n        if (!(o instanceof Move)) return false;\r\n\r\n        Move other = (Move) o;\r\n\r\n        if (!from.equals(other.from)) return false;\r\n        if (!to.equals(other.to)) return false;\r\n\r\n        // promotion-aware\r\n        return promotion == other.promotion;\r\n    ","comment":""},{"v":"+","ret":"int","n":"hashCode","p":"","ctor":false,"body":"\r\n        int result = from.hashCode();\r\n        result = 31 * result + to.hashCode();\r\n        result = 31 * result + (promotion != null ? promotion.hashCode() : 0);\r\n        return result;\r\n    ","comment":""}],"comment":"","rawBody":"\r\n\r\n    public final Position from;\r\n    public final Position to;\r\n    public final PieceType promotion; // null if not a promotion\r\n\r\n    // constructor (no promotion)\r\n    public Move(Position from, Position to) {\r\n        this(from, to, null);\r\n    }\r\n\r\n    // constructor for promotion\r\n    public Move(Position from, Position to, PieceType promotion) {\r\n        this.from = from;\r\n        this.to = to;\r\n        this.promotion = promotion;\r\n    }\r\n\r\n    //checks if both  are moves and are the same (from, to and promotion )\r\n    @Override\r\n    public boolean equals(Object o) {\r\n        if (this == o) return true;\r\n        if (!(o instanceof Move)) return false;\r\n\r\n        Move other = (Move) o;\r\n\r\n        if (!from.equals(other.from)) return false;\r\n        if (!to.equals(other.to)) return false;\r\n\r\n        // promotion-aware\r\n        return promotion == other.promotion;\r\n    }\r\n//another line of checking( hashcode)\r\n    @Override\r\n    public int hashCode() {\r\n        int result = from.hashCode();\r\n        result = 31 * result + to.hashCode();\r\n        result = 31 * result + (promotion != null ? promotion.hashCode() : 0);\r\n        return result;\r\n    }\r\n\r\n\r\n","internalCalls":[]},"x":-609.619407771256,"y":-315.84271247461896,"w":300,"h":256,"colH":66},{"cls":{"name":"MoveGenerator","par":[],"file":"MoveGenerator.java","type":"class","fields":[],"methods":[{"v":"+","ret":"List<Move>","n":"generateMoves","p":"board, from","ctor":false,"body":"\r\n\r\n        List<Move> moves = new ArrayList<>();\r\n\r\n        Piece piece = board.getPiece(from);\r\n        if (piece == null) return moves;  //prevent crash\r\n\r\n\r\n        if (piece.getType() == PieceType.PAWN) {\r\n            generatePawnMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.ROOK) {\r\n            generateRookMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.BISHOP) {\r\n            generateBishopMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.QUEEN) {\r\n            generateQueenMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.KNIGHT) {\r\n            generateKnightMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.KING) {\r\n            generateKingMoves(board, from, piece, moves);\r\n        }\r\n\r\n        return moves;\r\n    ","comment":""},{"v":"-","ret":"void","n":"generatePawnMoves","p":"board, from, piece, moves","ctor":false,"body":"\r\n        // checks colour\r\n        int direction = (piece.getColour() == PieceColour.WHITE) ? -1 : 1;\r\n        // One square forward\r\n\r\n        Position oneForward = new Position(from.x, from.y + direction);\r\n        // checks if it's on the board and empty\r\n        if (oneForward.isValid() && board.getPiece(oneForward) == null) {\r\n//promotes if reaches the end\r\n            if (isPromotionRank(oneForward, piece)) {\r\n                addPromotionMoves(from, oneForward, moves);\r\n            } else {\r\n                moves.add(new Move(from, oneForward));\r\n            }\r\n\r\n            // Two squares forward (first move only)\r\n            Position twoForward = new Position(from.x, from.y + 2 * direction);\r\n            //in addition checks if it has moved before\r\n            if (!piece.hasMoved() && twoForward.isValid()\r\n                    && board.getPiece(twoForward) == null) {\r\n                moves.add(new Move(from, twoForward));\r\n            }\r\n        }\r\n// Diagonal captures\r\n        int[] dx = {-1, 1}; // left & right\r\n//does left and right\r\n        for (int deltaX : dx) {\r\n            Position diagonal = new Position(from.x + deltaX, from.y + direction);\r\n// checks if it's on the board\r\n            if (!diagonal.isValid()) continue;\r\n\r\n            Piece target = board.getPiece(diagonal);\r\n// checks if its got a  piece and it's the other colour\r\n            if (target != null && target.getColour() != piece.getColour()) {\r\n// promotion\r\n                if (isPromotionRank(diagonal, piece)) {\r\n                    addPromotionMoves(from, diagonal, moves);\r\n                } else {\r\n                    // normal\r\n                    moves.add(new Move(from, diagonal));\r\n                }\r\n            }\r\n        }\r\n        // En passant\r\n        Move last = board.getLastMove();\r\n        if (last != null) {\r\n\r\n            Piece lastPiece = board.getPiece(last.to);\r\n            if (lastPiece == null) return;\r\n// checks if the last move was a pawn that moved twice\r\n            if (lastPiece.getType() == PieceType.PAWN &&\r\n                    //last move was a 2 forward\r\n                    Math.abs(last.to.y - last.from.y) == 2 &&\r\n                    //they are on the same y level\r\n                    last.to.y == from.y &&\r\n                    //checks that they are on the square next to\r\n                    Math.abs(last.to.x - from.x) == 1) {\r\n// checks direction according to colour and changes the y accordingly\r\n                int dir = (piece.getColour() == PieceColour.WHITE) ? -1 : 1;\r\n                Position target = new Position(last.to.x, from.y + dir);\r\n//checks that the move is on the board and adds it\r\n                if (target.isValid()) {\r\n                    moves.add(new Move(from, target));\r\n                }\r\n            }\r\n        }\r\n\r\n\r\n\r\n\r\n\r\n    ","comment":""},{"v":"-","ret":"boolean","n":"isPromotionRank","p":"pos, pawn","ctor":false,"body":"\r\n        return (pawn.getColour() == PieceColour.WHITE && pos.y == 0)\r\n                || (pawn.getColour() == PieceColour.BLACK && pos.y == 7);\r\n    ","comment":""},{"v":"-","ret":"void","n":"addPromotionMoves","p":"from, to, moves","ctor":false,"body":"\r\n        moves.add(new Move(from, to, PieceType.QUEEN));\r\n        moves.add(new Move(from, to, PieceType.ROOK));\r\n        moves.add(new Move(from, to, PieceType.BISHOP));\r\n        moves.add(new Move(from, to, PieceType.KNIGHT));\r\n    ","comment":""},{"v":"-","ret":"void","n":"generateRookMoves","p":"board, from, piece, moves","ctor":false,"body":"\r\n\r\n        // Directions: up, down, left, right\r\n        int[][] directions = {\r\n                {0, -1}, // up\r\n                {0, 1},  // down\r\n                {-1, 0}, // left\r\n                {1, 0}   // right\r\n        };\r\n// goes over the whole array\r\n        for (int[] dir : directions) {\r\n            int x = from.x + dir[0];\r\n            int y = from.y + dir[1];\r\n\r\n            while (true) {\r\n                //makes sure the positon is on the board\r\n                // if the square is empty or has an enemy piece the move is added\r\n                Position next = new Position(x, y);\r\n                if (!next.isValid()) break;\r\n\r\n                Piece target = board.getPiece(next);\r\n\r\n                if (target == null) {\r\n                    // Empty square → valid move\r\n                    moves.add(new Move(from, next));\r\n                } else {\r\n                    // Occupied square\r\n                    if (target.getColour() != piece.getColour()) {\r\n                        // Capture\r\n                        moves.add(new Move(from, next));\r\n                    }\r\n                    break; // Stop in this direction\r\n                }\r\n\r\n                x += dir[0];\r\n                y += dir[1];\r\n            }\r\n        }\r\n    ","comment":""},{"v":"-","ret":"void","n":"generateBishopMoves","p":"board, from, piece, moves","ctor":false,"body":"\r\n\r\n        // Directions: diagonals\r\n        int[][] directions = {\r\n                {1, 1},   // down-right\r\n                {1, -1},  // up-right\r\n                {-1, 1},  // down-left\r\n                {-1, -1}  // up-left\r\n        };\r\n// goes over the whole array(every direction)\r\n        for (int[] dir : directions) {\r\n            int x = from.x + dir[0];\r\n            int y = from.y + dir[1];\r\n\r\n            while (true) {\r\n                // makes sure the positon is on the board and the square is empty\r\n                // square can also have an enemy piece\r\n                // these moves are added to the list\r\n                Position next = new Position(x, y);\r\n                if (!next.isValid()) break;\r\n\r\n                Piece target = board.getPiece(next);\r\n\r\n                if (target == null) {\r\n                    // Empty square valid move\r\n                    moves.add(new Move(from, next));\r\n                } else {\r\n                    // Occupied square\r\n                    if (target.getColour() != piece.getColour()) {\r\n                        // Capture\r\n                        moves.add(new Move(from, next));\r\n                    }\r\n                    break; // Stop in this direction\r\n                }\r\n// continues in the direction\r\n                x += dir[0];\r\n                y += dir[1];\r\n            }\r\n        }\r\n    ","comment":""},{"v":"-","ret":"void","n":"generateQueenMoves","p":"board, from, piece, moves","ctor":false,"body":"\r\n\r\n        // Directions: rook (straight) + bishop (diagonal)\r\n        int[][] directions = {\r\n                {0, -1},  // up\r\n                {0, 1},   // down\r\n                {-1, 0},  // left\r\n                {1, 0},   // right\r\n                {1, 1},   // down-right\r\n                {1, -1},  // up-right\r\n                {-1, 1},  // down-left\r\n                {-1, -1}  // up-left\r\n        };\r\n// goes through each direction\r\n        for (int[] dir : directions) {\r\n            int x = from.x + dir[0];\r\n            int y = from.y + dir[1];\r\n\r\n            while (true) {\r\n                // makes sure the positon is on the board and the square is empty\r\n                // square can also have an enemy piece\r\n                // these moves are added to the list\r\n                Position next = new Position(x, y);\r\n                if (!next.isValid()) break;\r\n\r\n                Piece target = board.getPiece(next);\r\n\r\n                if (target == null) {\r\n                    // Empty square  valid move\r\n                    moves.add(new Move(from, next));\r\n                } else {\r\n                    // Occupied square\r\n                    if (target.getColour() != piece.getColour()) {\r\n                        // Capture\r\n                        moves.add(new Move(from, next));\r\n                    }\r\n                    break; // Stop in this direction\r\n                }\r\n\r\n                x += dir[0];\r\n                y += dir[1];\r\n            }\r\n        }\r\n    ","comment":""},{"v":"-","ret":"void","n":"generateKnightMoves","p":"board, from, piece, moves","ctor":false,"body":"\r\n\r\n        // All L-shaped knight moves\r\n        int[][] offsets = {\r\n                {1, 2}, {2, 1},\r\n                {-1, 2}, {-2, 1},\r\n                {1, -2}, {2, -1},\r\n                {-1, -2}, {-2, -1}\r\n        };\r\n// goes through all of the directions\r\n        for (int[] offset : offsets) {\r\n            Position target = new Position(\r\n                    from.x + offset[0],\r\n                    from.y + offset[1]\r\n            );\r\n            // makes sure the positon is on the board and the square is empty\r\n            // square can also have an enemy piece\r\n            // these moves are added to the list\r\n            if (!target.isValid()) continue;\r\n\r\n            Piece occupant = board.getPiece(target);\r\n\r\n            if (occupant == null || occupant.getColour() != piece.getColour()) {\r\n                // Empty square or enemy piece\r\n                moves.add(new Move(from, target));\r\n            }\r\n        }\r\n    ","comment":""},{"v":"-","ret":"void","n":"generateKingMoves","p":"board, from, king, moves","ctor":false,"body":"\r\n\r\n        // All 8 surrounding squares\r\n        int[][] directions = {\r\n                {0, -1},  // up\r\n                {0, 1},   // down\r\n                {-1, 0},  // left\r\n                {1, 0},   // right\r\n                {1, 1},   // down-right\r\n                {1, -1},  // up-right\r\n                {-1, 1},  // down-left\r\n                {-1, -1}  // up-left\r\n        };\r\n// goes through all of the directions\r\n        for (int[] dir : directions) {\r\n            Position target = new Position(from.x + dir[0], from.y + dir[1]);\r\n            // makes sure the positon is on the board and the square is empty\r\n            // square can also have an enemy piece\r\n            // these moves are added to the list\r\n            if (!target.isValid()) continue;\r\n\r\n            Piece occupant = board.getPiece(target);\r\n\r\n            if (occupant == null || occupant.getColour() != king.getColour()) {\r\n                moves.add(new Move(from, target));\r\n            }\r\n        }\r\n\r\n        // Add castling moves\r\n        generateCastlingMoves(board, from, king, moves);\r\n    ","comment":""},{"v":"-","ret":"void","n":"generateCastlingMoves","p":"board, from, king, moves","ctor":false,"body":"\r\n// gets the king row and colour\r\n        PieceColour colour = king.getColour();\r\n        int row = from.y;\r\n\r\n        // King must not currently be in check\r\n        if (CheckDetector.isKingInCheck(board, colour)) return;\r\n\r\n        //  Kingside castling after checking if rook or king have moved\r\n        if (board.canCastleKingSide(colour)) {\r\n\r\n            Position f = new Position(5, row);\r\n            Position g = new Position(6, row);\r\n// makes sure those squares are empty and don't go into check\r\n            if (board.getPiece(f) == null &&\r\n                    board.getPiece(g) == null &&\r\n\r\n                    !CheckDetector.isSquareAttacked(board, f, colour) &&\r\n                    !CheckDetector.isSquareAttacked(board, g, colour)) {\r\n\r\n                moves.add(new Move(from, g));\r\n            }\r\n        }\r\n\r\n        // Queenside castling\r\n        if (board.canCastleQueenSide(colour)) {\r\n\r\n            Position b = new Position(1, row);\r\n            Position c = new Position(2, row);\r\n            Position d = new Position(3, row);\r\n// makes sure those squares are empty and don't go into check\r\n            if (board.getPiece(b) == null &&\r\n                    board.getPiece(c) == null &&\r\n                    board.getPiece(d) == null &&\r\n\r\n                    !CheckDetector.isSquareAttacked(board, d, colour) &&\r\n                    !CheckDetector.isSquareAttacked(board, c, colour)) {\r\n\r\n                moves.add(new Move(from, c));\r\n            }\r\n        }\r\n    ","comment":""}],"comment":"","rawBody":"\r\n\r\n    //main function that activates the other move generations according\r\n    public static List<Move> generateMoves(Board board, Position from) {\r\n\r\n        List<Move> moves = new ArrayList<>();\r\n\r\n        Piece piece = board.getPiece(from);\r\n        if (piece == null) return moves;  //prevent crash\r\n\r\n\r\n        if (piece.getType() == PieceType.PAWN) {\r\n            generatePawnMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.ROOK) {\r\n            generateRookMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.BISHOP) {\r\n            generateBishopMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.QUEEN) {\r\n            generateQueenMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.KNIGHT) {\r\n            generateKnightMoves(board, from, piece, moves);\r\n        }\r\n        if (piece.getType() == PieceType.KING) {\r\n            generateKingMoves(board, from, piece, moves);\r\n        }\r\n\r\n        return moves;\r\n    }\r\n    // generates all moves for pawn(pseudo) and adds them to the arraylist\r\n    private static void generatePawnMoves(Board board, Position from, Piece piece, List<Move> moves) {\r\n        // checks colour\r\n        int direction = (piece.getColour() == PieceColour.WHITE) ? -1 : 1;\r\n        // One square forward\r\n\r\n        Position oneForward = new Position(from.x, from.y + direction);\r\n        // checks if it's on the board and empty\r\n        if (oneForward.isValid() && board.getPiece(oneForward) == null) {\r\n//promotes if reaches the end\r\n            if (isPromotionRank(oneForward, piece)) {\r\n                addPromotionMoves(from, oneForward, moves);\r\n            } else {\r\n                moves.add(new Move(from, oneForward));\r\n            }\r\n\r\n            // Two squares forward (first move only)\r\n            Position twoForward = new Position(from.x, from.y + 2 * direction);\r\n            //in addition checks if it has moved before\r\n            if (!piece.hasMoved() && twoForward.isValid()\r\n                    && board.getPiece(twoForward) == null) {\r\n                moves.add(new Move(from, twoForward));\r\n            }\r\n        }\r\n// Diagonal captures\r\n        int[] dx = {-1, 1}; // left & right\r\n//does left and right\r\n        for (int deltaX : dx) {\r\n            Position diagonal = new Position(from.x + deltaX, from.y + direction);\r\n// checks if it's on the board\r\n            if (!diagonal.isValid()) continue;\r\n\r\n            Piece target = board.getPiece(diagonal);\r\n// checks if its got a  piece and it's the other colour\r\n            if (target != null && target.getColour() != piece.getColour()) {\r\n// promotion\r\n                if (isPromotionRank(diagonal, piece)) {\r\n                    addPromotionMoves(from, diagonal, moves);\r\n                } else {\r\n                    // normal\r\n                    moves.add(new Move(from, diagonal));\r\n                }\r\n            }\r\n        }\r\n        // En passant\r\n        Move last = board.getLastMove();\r\n        if (last != null) {\r\n\r\n            Piece lastPiece = board.getPiece(last.to);\r\n            if (lastPiece == null) return;\r\n// checks if the last move was a pawn that moved twice\r\n            if (lastPiece.getType() == PieceType.PAWN &&\r\n                    //last move was a 2 forward\r\n                    Math.abs(last.to.y - last.from.y) == 2 &&\r\n                    //they are on the same y level\r\n                    last.to.y == from.y &&\r\n                    //checks that they are on the square next to\r\n                    Math.abs(last.to.x - from.x) == 1) {\r\n// checks direction according to colour and changes the y accordingly\r\n                int dir = (piece.getColour() == PieceColour.WHITE) ? -1 : 1;\r\n                Position target = new Position(last.to.x, from.y + dir);\r\n//checks that the move is on the board and adds it\r\n                if (target.isValid()) {\r\n                    moves.add(new Move(from, target));\r\n                }\r\n            }\r\n        }\r\n\r\n\r\n\r\n\r\n\r\n    }\r\n    // checks the colour and y value to see if it's on the last rank and therefore can promote\r\n    private static boolean isPromotionRank(Position pos, Piece pawn) {\r\n        return (pawn.getColour() == PieceColour.WHITE && pos.y == 0)\r\n                || (pawn.getColour() == PieceColour.BLACK && pos.y == 7);\r\n    }\r\n// adds all the options for promotion and the position\r\n    private static void addPromotionMoves(Position from, Position to, List<Move> moves) {\r\n        moves.add(new Move(from, to, PieceType.QUEEN));\r\n        moves.add(new Move(from, to, PieceType.ROOK));\r\n        moves.add(new Move(from, to, PieceType.BISHOP));\r\n        moves.add(new Move(from, to, PieceType.KNIGHT));\r\n    }\r\n\r\n    // generates all moves for rook(pseudo) and adds them to the arraylist\r\n    private static void generateRookMoves(Board board, Position from, Piece piece, List<Move> moves) {\r\n\r\n        // Directions: up, down, left, right\r\n        int[][] directions = {\r\n                {0, -1}, // up\r\n                {0, 1},  // down\r\n                {-1, 0}, // left\r\n                {1, 0}   // right\r\n        };\r\n// goes over the whole array\r\n        for (int[] dir : directions) {\r\n            int x = from.x + dir[0];\r\n            int y = from.y + dir[1];\r\n\r\n            while (true) {\r\n                //makes sure the positon is on the board\r\n                // if the square is empty or has an enemy piece the move is added\r\n                Position next = new Position(x, y);\r\n                if (!next.isValid()) break;\r\n\r\n                Piece target = board.getPiece(next);\r\n\r\n                if (target == null) {\r\n                    // Empty square → valid move\r\n                    moves.add(new Move(from, next));\r\n                } else {\r\n                    // Occupied square\r\n                    if (target.getColour() != piece.getColour()) {\r\n                        // Capture\r\n                        moves.add(new Move(from, next));\r\n                    }\r\n                    break; // Stop in this direction\r\n                }\r\n\r\n                x += dir[0];\r\n                y += dir[1];\r\n            }\r\n        }\r\n    }\r\n\r\n    // generates all moves for bishop(pseudo) and adds them to the arraylist\r\n    private static void generateBishopMoves(Board board, Position from, Piece piece, List<Move> moves) {\r\n\r\n        // Directions: diagonals\r\n        int[][] directions = {\r\n                {1, 1},   // down-right\r\n                {1, -1},  // up-right\r\n                {-1, 1},  // down-left\r\n                {-1, -1}  // up-left\r\n        };\r\n// goes over the whole array(every direction)\r\n        for (int[] dir : directions) {\r\n            int x = from.x + dir[0];\r\n            int y = from.y + dir[1];\r\n\r\n            while (true) {\r\n                // makes sure the positon is on the board and the square is empty\r\n                // square can also have an enemy piece\r\n                // these moves are added to the list\r\n                Position next = new Position(x, y);\r\n                if (!next.isValid()) break;\r\n\r\n                Piece target = board.getPiece(next);\r\n\r\n                if (target == null) {\r\n                    // Empty square valid move\r\n                    moves.add(new Move(from, next));\r\n                } else {\r\n                    // Occupied square\r\n                    if (target.getColour() != piece.getColour()) {\r\n                        // Capture\r\n                        moves.add(new Move(from, next));\r\n                    }\r\n                    break; // Stop in this direction\r\n                }\r\n// continues in the direction\r\n                x += dir[0];\r\n                y += dir[1];\r\n            }\r\n        }\r\n    }\r\n    // generates all moves for queen(pseudo) and adds them to the arraylist\r\n    private static void generateQueenMoves(Board board, Position from, Piece piece, List<Move> moves) {\r\n\r\n        // Directions: rook (straight) + bishop (diagonal)\r\n        int[][] directions = {\r\n                {0, -1},  // up\r\n                {0, 1},   // down\r\n                {-1, 0},  // left\r\n                {1, 0},   // right\r\n                {1, 1},   // down-right\r\n                {1, -1},  // up-right\r\n                {-1, 1},  // down-left\r\n                {-1, -1}  // up-left\r\n        };\r\n// goes through each direction\r\n        for (int[] dir : directions) {\r\n            int x = from.x + dir[0];\r\n            int y = from.y + dir[1];\r\n\r\n            while (true) {\r\n                // makes sure the positon is on the board and the square is empty\r\n                // square can also have an enemy piece\r\n                // these moves are added to the list\r\n                Position next = new Position(x, y);\r\n                if (!next.isValid()) break;\r\n\r\n                Piece target = board.getPiece(next);\r\n\r\n                if (target == null) {\r\n                    // Empty square  valid move\r\n                    moves.add(new Move(from, next));\r\n                } else {\r\n                    // Occupied square\r\n                    if (target.getColour() != piece.getColour()) {\r\n                        // Capture\r\n                        moves.add(new Move(from, next));\r\n                    }\r\n                    break; // Stop in this direction\r\n                }\r\n\r\n                x += dir[0];\r\n                y += dir[1];\r\n            }\r\n        }\r\n    }\r\n    // generates all moves for knight(pseudo) and adds them to the arraylist\r\n    private static void generateKnightMoves(Board board, Position from, Piece piece, List<Move> moves) {\r\n\r\n        // All L-shaped knight moves\r\n        int[][] offsets = {\r\n                {1, 2}, {2, 1},\r\n                {-1, 2}, {-2, 1},\r\n                {1, -2}, {2, -1},\r\n                {-1, -2}, {-2, -1}\r\n        };\r\n// goes through all of the directions\r\n        for (int[] offset : offsets) {\r\n            Position target = new Position(\r\n                    from.x + offset[0],\r\n                    from.y + offset[1]\r\n            );\r\n            // makes sure the positon is on the board and the square is empty\r\n            // square can also have an enemy piece\r\n            // these moves are added to the list\r\n            if (!target.isValid()) continue;\r\n\r\n            Piece occupant = board.getPiece(target);\r\n\r\n            if (occupant == null || occupant.getColour() != piece.getColour()) {\r\n                // Empty square or enemy piece\r\n                moves.add(new Move(from, target));\r\n            }\r\n        }\r\n    }\r\n   // generates all moves for king(pseudo) and adds them to the arraylist\r\n    private static void generateKingMoves(Board board, Position from, Piece king, List<Move> moves) {\r\n\r\n        // All 8 surrounding squares\r\n        int[][] directions = {\r\n                {0, -1},  // up\r\n                {0, 1},   // down\r\n                {-1, 0},  // left\r\n                {1, 0},   // right\r\n                {1, 1},   // down-right\r\n                {1, -1},  // up-right\r\n                {-1, 1},  // down-left\r\n                {-1, -1}  // up-left\r\n        };\r\n// goes through all of the directions\r\n        for (int[] dir : directions) {\r\n            Position target = new Position(from.x + dir[0], from.y + dir[1]);\r\n            // makes sure the positon is on the board and the square is empty\r\n            // square can also have an enemy piece\r\n            // these moves are added to the list\r\n            if (!target.isValid()) continue;\r\n\r\n            Piece occupant = board.getPiece(target);\r\n\r\n            if (occupant == null || occupant.getColour() != king.getColour()) {\r\n                moves.add(new Move(from, target));\r\n            }\r\n        }\r\n\r\n        // Add castling moves\r\n        generateCastlingMoves(board, from, king, moves);\r\n    }\r\n\r\n    // generates all the castling options(if valid) and adds them to the arraylist\r\n    private static void generateCastlingMoves(Board board, Position from, Piece king, List<Move> moves) {\r\n// gets the king row and colour\r\n        PieceColour colour = king.getColour();\r\n        int row = from.y;\r\n\r\n        // King must not currently be in check\r\n        if (CheckDetector.isKingInCheck(board, colour)) return;\r\n\r\n        //  Kingside castling after checking if rook or king have moved\r\n        if (board.canCastleKingSide(colour)) {\r\n\r\n            Position f = new Position(5, row);\r\n            Position g = new Position(6, row);\r\n// makes sure those squares are empty and don't go into check\r\n            if (board.getPiece(f) == null &&\r\n                    board.getPiece(g) == null &&\r\n\r\n                    !CheckDetector.isSquareAttacked(board, f, colour) &&\r\n                    !CheckDetector.isSquareAttacked(board, g, colour)) {\r\n\r\n                moves.add(new Move(from, g));\r\n            }\r\n        }\r\n\r\n        // Queenside castling\r\n        if (board.canCastleQueenSide(colour)) {\r\n\r\n            Position b = new Position(1, row);\r\n            Position c = new Position(2, row);\r\n            Position d = new Position(3, row);\r\n// makes sure those squares are empty and don't go into check\r\n            if (board.getPiece(b) == null &&\r\n                    board.getPiece(c) == null &&\r\n                    board.getPiece(d) == null &&\r\n\r\n                    !CheckDetector.isSquareAttacked(board, d, colour) &&\r\n                    !CheckDetector.isSquareAttacked(board, c, colour)) {\r\n\r\n                moves.add(new Move(from, c));\r\n            }\r\n        }\r\n    }\r\n\r\n\r\n\r\n","internalCalls":[{"from":{"v":"+","ret":"List<Move>","n":"generateMoves","p":"board, 