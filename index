ally show it\n        });\n\n\n    ","comment":""}},{"from":"MainActivity","to":"StartActivity","kind":"uses","label":"משתמש ב‑StartActivity (בגוף הפונקציה)","fld":null,"mth":{"v":"#","ret":"void","n":"onCreate","p":"savedInstanceState","ctor":false,"body":"\n        //opens screen\n        super.onCreate(savedInstanceState);\n        setContentView(R.layout.activity_main);\n\n        gameOverBanner = findViewById(R.id.gameOverBanner);\n        tvGameOverMessage = findViewById(R.id.tvGameOverMessage);\n\n        // Window insets( adjusts the screen)\n        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main), (v, insets) -> {\n            Insets systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars());\n            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom);\n            return insets;\n        });\n\n        // Game logic object\n        gameState = new GameState();\n\n        //  Read intent ONCE\n        Intent intent = getIntent();\n        whitePlayerName = intent.getStringExtra(\"PLAYER_WHITE\");\n        blackPlayerName = intent.getStringExtra(\"PLAYER_BLACK\");\n        gameTimeMinutes = intent.getIntExtra(\"GAME_TIME\", 0);\n\n        boolean isFirstGame = intent.getBooleanExtra(\"IS_FIRST_GAME\", true);\n        whiteScore = intent.getDoubleExtra(\"WHITE_SCORE\", 0);\n        blackScore = intent.getDoubleExtra(\"BLACK_SCORE\", 0);\n\n        //  Set player names\n        TextView tvWhite = findViewById(R.id.tvPlayerWhite);\n        TextView tvBlack = findViewById(R.id.tvPlayerBlack);\n        tvWhite.setText(\"White: \" + whitePlayerName);\n        tvBlack.setText(\"Black: \" + blackPlayerName);\n\n        //  Score UI (ONLY from second game)\n        TextView tvWhiteScore = findViewById(R.id.tvWhiteScore);\n        TextView tvBlackScore = findViewById(R.id.tvBlackScore);\n\n// doesn't show score on first game\n        if (isFirstGame) {\n            tvWhiteScore.setVisibility(View.GONE);\n 