 correct image back to the square according to colour\n        boolean white = piece.getColour() == PieceColour.WHITE;\n        //checks type of piece\n        switch (piece.getType()) {\n            case KING:\n                return white ? R.drawable.w_king : R.drawable.b_king;\n            case QUEEN:\n                return white ? R.drawable.w_queen : R.drawable.b_queen;\n            case ROOK:\n                return white ? R.drawable.w_rook : R.drawable.b_rook;\n            case BISHOP:\n                return white ? R.drawable.w_bishop : R.drawable.b_bishop;\n            case KNIGHT:\n                return white ? R.drawable.w_knight : R.drawable.b_knight;\n            case PAWN:\n                return white ? R.drawable.w_pawn : R.drawable.b_pawn;\n        }\n//safety\n        throw new IllegalStateException(\"Unknown piece type\");\n    ","comment":""}},{"from":{"v":"-","ret":"void","n":"renderBoard","p":"","ctor":false,"body":"\n\n        clearAllHighlights();\n//cleans all pieces from last game\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n                squareViews[row][col].removeAllViews();\n            }\n        }\n        //places the pieces\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n//checks if a piece needs to go there\n                Piece piece = board().getPiece(new Position(col, row));\n                if (piece == null) continue;\n//places the right piece on the board\n                ImageView pieceView = new ImageView(this);\n                pieceView.setImageResource(getPieceDrawable(piece));\n                pieceView.setScaleType(ImageView.ScaleType.CENTER_INSIDE);\n                //adds piece\n                squareViews[row][col].addView(pieceView);\n            }\n        }\n    ","comment":""},"to":{"v":"-","ret":"void","n":"clearAllHighlights","p":"","ctor":false,"body":"\n        clearSelection();\n        clearMoveHighlights();\n    ","comment":""}},{"from":{"v":"-","ret":"void","n":"onSquareClicked","p":"view","ctor":false,"body":"\n        //filters clicks out of play\n        if (gameOver || awaitingPromotion) return;\n        //checks if piece is on square\n        SquareTag tag = (SquareTag) view.getTag();\n        Piece clickedPiece = board().getPiece(\n                new Position(tag.col, tag.row)\n        );\n\n        // 1️ No piece selected yet(opponent' / empty)\n        if (selectedSquare == null) {\n            if (clickedPiece == null) return;\n            if (clickedPiece.getColour() != currentTurn()) return;\n\n//visual update by marking square and possible moves\n            selectSquare(view);\n            showLegalMoves(tag);\n            return;\n        }\n\n        //  Same square → deselect\n        if (view == selectedSquare) {\n            clearSelection();\n            clearMoveHighlights();\n            currentLegalMoves.clear();\n            return;\n        }\n\n        //  Try execute move\n        Move move = getMoveTo(tag);\n\n        if (move != null) {\n            executeMove(move);\n        }\n\n        clearSelection();\n        clearMoveHighlights();\n        currentLegalMoves.clear();\n    ","comment":""},"to":{"v":"-","ret":"Board","n":"board","p":"","ctor":false,"body":"\n        return gameState.getBoard();\n    ","comment":""}},{"from":{"v":"-","ret":"void","n":"onSquareClicked","p":"view","ctor":false,"body":"\n        //filters clicks out of play\n        if (gameOver || awaitingPromotion) return;\n        //checks if piece is on square\n        SquareTag tag = (SquareTag) view.getTag();\n        Piece clickedPiece = board().getPiece(\n                new Position(tag.col, tag.row)\n        );\n\n        // 1️ No piece selected yet(opponent' / empty)\n        if (selectedSquare == null) {\n            if (clickedPiece == null) return;\n            if (clickedPiece.getColour() != currentTurn()) return;\n\n//visual update by marking square 