gs\n            selectedSquare = null;\n            selectedTag = null;\n        }\n    ","comment":""},{"v":"-","ret":"View","n":"createMoveDot","p":"","ctor":false,"body":"\n        View dot = new View(this);\n        //defines it\n        int size = (int) (18 * getResources().getDisplayMetrics().density); // 18dp\n\n        FrameLayout.LayoutParams params =\n                new FrameLayout.LayoutParams(size, size);\n        params.gravity = android.view.Gravity.CENTER;\n//adds the dot\n        dot.setLayoutParams(params);\n        dot.setBackgroundResource(R.drawable.move_dot);\n\n        return dot;\n    ","comment":""},{"v":"-","ret":"View","n":"createCaptureRing","p":"","ctor":false,"body":"\n        View ring = new View(this);\n//defines it on top of the piece\n        FrameLayout.LayoutParams params =\n                new FrameLayout.LayoutParams(\n                        FrameLayout.LayoutParams.MATCH_PARENT,\n                        FrameLayout.LayoutParams.MATCH_PARENT\n                );\n        params.gravity = android.view.Gravity.CENTER;\n//adds it\n        ring.setLayoutParams(params);\n        ring.setBackgroundResource(R.drawable.capture_ring);\n\n        return ring;\n    ","comment":""},{"v":"-","ret":"void","n":"clearMoveHighlights","p":"","ctor":false,"body":"\n        for (View square : highlightedSquares) {\n            //remove dots\n            View dot = (View) square.getTag(R.id.move_dot);\n            if (dot != null) {\n                ((FrameLayout) square).removeView(dot);\n                square.setTag(R.id.move_dot, null);\n            }\n//remove rings\n            View ring = (View) square.getTag(R.id.capture_ring);\n            if (ring != null) {\n                ((FrameLayout) square).removeView(ring);\n                square.setTag(R.id.capture_ring, null);\n            }\n        }\n        highlightedSquares.clear();\n    ","comment":""},{"v":"-","ret":"void","n":"showLegalMoves","p":"fromTag","ctor":false,"body":"\n//remove marks\n        clearMoveHighlights();\n\n        Position from = new Position(fromTag.col, fromTag.row);\n//gets all moves including pins\n        List<Move> pseudoMoves = MoveGenerator.generateMoves(board(), from);\n        currentLegalMoves.clear();\n//checks if moves put in check\n        for (Move move : pseudoMoves) {\n            if (MoveValidator.isLegalMove(board(), move, currentTurn())) {\n                currentLegalMoves.add(move);\n//verify position\n                int row = move.to.y;\n                int col = move.to.x;\n                View targetSquare = squareViews[row][col];\n                Piece targetPiece = board().getPiece(move.to);\n\n                if (targetPiece == null) {\n                    // Normal move → dot\n                    View dot = createMoveDot();\n                    targetSquare.setTag(R.id.move_dot, dot);\n                    ((FrameLayout) targetSquare).addView(dot);\n                    //if there is a targeted piece it puts a ring\n                } else {\n                    // Capture  ring\n                    View ring = createCaptureRing();\n                    targetSquare.setTag(R.id.capture_ring, ring);\n                    ((FrameLayout) targetSquare).addView(ring);\n                }\n//adds it to highlighted squares\n                highlightedSquares.add(targetSquare);\n\n            }\n        }\n    ","comment":""},{"v":"-","ret":"Move","n":"getMoveTo","p":"toTag","ctor":false,"body":"\n\n        for (Move move : currentLegalMoves) {\n            if (move.to.x == toTag.col && move.to.y == toTag.row) {\n                //returns info about move\n                return move;\n            }\n        }\n        return null;\n    ","comment":""},{"v":"-","ret":"void","n":"executeMove","p":"move","ctor":false,"body":"\n\n        // Try to make move via GameState make move rules\n        boolean moved = gameState.makeMove(move);\n        if (!moved) return;\n\n        // Check promotion AFTER move\n        Piece pieceAtDestination = board().getPiece(move.to);\n\n        if (pieceAtDestination != null &&\n                pieceAtDestination.getType() == PieceType.PAWN) {\n//finds correct y position\n            int promotionRow =\n                    (pieceAtDestination.getColour() == PieceColour.WHITE) ? 0 : 7;\n\n            if (move.to.y == promotionRow) {\n                awaitingPromotion = true;\n\n                // Pause timers\n                whiteTimer.cancel();\n                blackTimer.cancel();\n//shows promotion dialog\n                showPromotionDialog(move.to, pieceAtDestination.getColour());\n                return;\n            }\n        }\n\n        // Move is complete and calls next function\n        onMoveFinished();\n    ","comment":""},{"v":"-","ret":"void","n":"showPromotionDialog","p":"position, colour","ctor":false,"body":"\n\n        View view = getLayoutInflater().inflate(R.layout.dialog_promotion, null);\n\n        ImageView queen  = view.findViewById(R.id.promoQueen);\n        ImageView rook   = view.findViewById(R.id.promoRook);\n        ImageView bishop = view.findViewById(R.id.promoBishop);\n        ImageView knight = view.findViewById(R.id.promoKnight);\n\n        // Set correct icons based on colour\n        if (colour == PieceColour.WHITE) {\n            queen.setImageResource(R.drawable.w_queen);\n            rook.setImageResource(R.drawable.w_rook);\n            bishop.setImageResource(R.drawable.w_bishop);\n            knight.setImageResource(R.drawable.w_knight);\n        } else {\n            queen.setImageResource(R.drawable.b_queen);\n            rook.setImageResource(R.drawable.b_rook);\n            bishop.setImageResource(R.drawable.b_bishop);\n            knight.setImageResource(R.drawable.b_knight);\n        }\n//define dialog\n        androidx.appcompat.app.AlertDialog dialog =\n                new androidx.appcompat.app.AlertDialog.Builder(this)\n                        .setTitle(\"Promote pawn\")\n                        .setCancelable(false)\n                        .setView(view)\n                        .create();\n//calls promote function according to choice\n        queen.setOnClickListener(v ->\n                promote(position, PieceType.QUEEN, dialog));\n        rook.setOnClickListener(v ->\n                promote(position, PieceType.ROOK, dialog));\n        bishop.setOnClickListener(v ->\n                promote(position, PieceType.BISHOP, dialog));\n        knight.setOnClickListener(v ->\n                promote(position, PieceType.KNIGHT, dialog));\n\n        dialog.show();\n    ","comment":""},{"v":"-","ret":"void","n":"promote","p":"position, type, dialog","ctor":false,"body":"\n//gets pawn and has safety check\n        Piece pawn = board().getPiece(position);\n        if (pawn == null) return;\n//replaces piece\n        board().setPiece(position, new Piece(type, pawn.getColour()));\n//promotion done\n        dialog.dismiss();\n        awaitingPromotion = false;\n\n        onMoveFinished();\n    ","comment":""},{"v":"-","ret":"void","n":"onMoveFinished","p":"","ctor":false,"body":"\n\n        clearAllHighlights();\n\n        stopTimers();\n//checks for game over\n        if (gameState.isGameOver()) {\n            handleGameOver();\n            renderBoard();\n            return;\n        }\n//start other player's clock\n        startTimerForCurrentTurn();\n//checks for highlight\n        showCheckIfNeeded();\n        renderBoard();\n    ","comment":""},{"v":"-","ret":"void","n":"startTimerForCurrentTurn","p":"","ctor":false,"body":"\n        if (gameOver) return;\n        //change clock colour\n        updateClockStyles();\n        createTimers(); // recreate using REMAINING time\n//start the correct clock\n        if (currentTurn() == PieceColour.WHITE) {\n            whiteTimer.start();\n        } else {\n            blackTimer.start();\n        }\n    ","comment":""},{"v":"-","ret":"void","n":"stopTimers","p":"","ctor":false,"body":"\n        //safety if and stops both times\n        if (whiteTimer != null) whiteTimer.cancel();\n        if (blackTimer != null) blackTimer.cancel();\n    ","comment":""},{"v":"-","ret":"void","n":"showCheckIfNeeded","p":"","ctor":false,"body":"\n\n        clearCheckHighlight();\n//checks check\n        if (!CheckDetector.isKingInCheck(board(), currentTurn())) return;\n//safety check\n        Position kingPos = board().findKing(currentTurn());\n        if (kingPos == null) return;\n//gets matching positons in view and set colour\n        View kingSquare = squareViews[kingPos.y][kingPos.x];\n        kingSquare.setForeground(\n                new ColorDrawable(Color.parseColor(\"#88FF0000\"))\n        );\n    ","comment":""},{"v":"-","ret":"void","n":"restartGame","p":"","ctor":false,"body":"\n        stopTimers();\n//change back colour from handle game over\n        GridLayout chessBoard = findViewById(R.id.chessBoard);\n        chessBoard.setAlpha(1f);\n        chessBoard.setEnabled(true);\n//change back  the function checks to false\n        gameState = new GameState();\n        gameOver = false;\n        awaitingPromotion = false;\n//resets clock\n        initClocks(gameTimeMinutes);\n        whiteTimer.start(); // White starts\n//clear the banner\n        gameOverBanner.setVisibility(View.GONE);\n//clear highlights and reset board\n        clearAllHighlights();\n        clearCheckHighlight();\n        updateClockStyles();\n        renderBoard();\n    ","comment":""},{"v":"-","ret":"void","n":"clearAllHighlights","p":"","ctor":false,"body":"\n        clearSelection();\n        clearMoveHighlights();\n    ","comment":""},{"v":"-","ret":"void","n":"initClocks","p":"minutes","ctor":false,"body":"\n//convert time to millisecond\n        whiteTimeMs = minutes * 60 * 1000L;\n        blackTimeMs = minutes * 60 * 1000L;\n\n        tvWhiteClock = findViewById(R.id.tvWhiteClock);\n        tvBlackClock = findViewById(R.id.tvBlackClock);\n//connect back the time\n        updateClockText(tvWhiteClock, whiteTimeMs);\n        updateClockText(tvBlackClock, blackTimeMs);\n\n        createTimers();\n    ","comment":""}],"comment":"","rawBody":"\n    private View selectedSquare = null;\n    private SquareTag selectedTag = null;\n\n    private FrameLayout[][] squareViews = new FrameLayout[8][8];\n\n    private final List<View> highlightedSquares = new ArrayList<>();\n    private List<Move> currentLegalMoves = new ArrayList<>();\n    private boolean gameOver = false;\n    private boolean awaitingPromotion = false;\n    private String whitePlayerName;\n    private String blackPlayerName;\n    private int gameTimeMinutes;\n    private CountDownTimer whiteTimer;\n    private CountDownTimer blackTimer;\n\n    private long whiteTimeMs;\n    private long blackTimeMs;\n\n    private TextView tvWhiteClock;\n    private TextView tvBlackClock;\n    private GameState gameState;\n    private LinearLayout gameOverBanner;\n    private TextView tvGameOverMessage;\n    private double whiteScore = 0.0;\n    private double blackScore = 0.0;\n\n\n    @Override\n    protected void onCreate(Bundle savedInstanceState) {\n        //opens screen\n        super.onCreate(savedInstanceState);\n        setContentView(R.layout.activity_main);\n\n        gameOverBanner = findViewById(R.id.gameOverBanner);\n        tvGameOverMessage = findViewById(R.id.tvGameOverMessage);\n\n        // Window insets( adjusts the screen)\n        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main), (v, insets) -> {\n            Insets systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars());\n            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom);\n            return insets;\n        });\n\n        // Game logic object\n        gameState = new GameState();\n\n        //  Read intent ONCE\n        Intent intent = getIntent();\n        whitePlayerName = intent.getStringExtra(\"PLAYER_WHITE\");\n        blackPlayerName = intent.getStringExtra(\"PLAYER_BLACK\");\n        gameTimeMinutes = intent.getIntExtra(\"GAME_TIME\", 0);\n\n        boolean isFirstGame = intent.getBooleanExtra(\"IS_FIRST_GAME\", true);\n        whiteScore = intent.getDoubleExtra(\"WHITE_SCORE\", 0);\n        blackScore = intent.getDoubleExtra(\"BLACK_SCORE\", 0);\n\n        //  Set player names\n        TextView tvWhite = findViewById(R.id.tvPlayerWhite);\n        TextView tvBlack = findViewById(R.id.tvPlayerBlack);\n        tvWhite.setText(\"White: \" + whitePlayerName);\n        tvBlack.setText(\"Black: \" + blackPlayerName);\n\n        //  Score UI (ONLY from second game)\n        TextView tvWhiteScore = findViewById(R.id.tvWhiteScore);\n        TextView tvBlackScore = findViewById(R.id.tvBlackScore);\n\n// doesn't show score on first game\n        if (isFirstGame) {\n            tvWhiteScore.setVisibility(View.GONE);\n            tvBlackScore.setVisibility(View.GONE);\n        } else {\n            tvWhiteScore.setVisibility(View.VISIBLE);\n            tvBlackScore.setVisibility(View.VISIBLE);\n            updateScoreUI();\n        }\n\n\n        //  Init clocks\n        initClocks(gameTimeMinutes);\n        whiteTimer.start(); // White starts\n\n        //  Build board\n        createChessBoard();\n        makeBoardSquare();\n\n        // Leave button endscreen\n        Button btnLeave = findViewById(R.id.btnLeave);\n        btnLeave.setOnClickListener(v -> {\n            Intent leaveIntent = new Intent(MainActivity.this, StartActivity.class);\n            leaveIntent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_NEW_TASK);\n            startActivity(leaveIntent);\n            finish();\n        });\n\n        // New Game button endscreen\n        Button btnNewGame = findViewById(R.id.btnNewGame);\n        btnNewGame.setOnClickListener(v -> {\n            Intent newGameIntent = new Intent(MainActivity.this, MainActivity.class);\n\n            newGameIntent.putExtra(\"PLAYER_WHITE\", whitePlayerName);\n            newGameIntent.putExtra(\"PLAYER_BLACK\", blackPlayerName);\n            newGameIntent.putExtra(\"GAME_TIME\", gameTimeMinutes);\n\n            newGameIntent.putExtra(\"WHITE_SCORE\", whiteScore);\n            newGameIntent.putExtra(\"BLACK_SCORE\", blackScore);\n            newGameIntent.putExtra(\"IS_FIRST_GAME\", false);\n            startActivity(newGameIntent);\n            finish();\n        });\n\n        ImageButton menuButton = findViewById(R.id.menuButton);\n\n        menuButton.setOnClickListener(v -> {\n            // Create popup menu here\n            PopupMenu popupMenu = new PopupMenu(this, v);\n            popupMenu.getMenuInflater().inflate(R.menu.menu, popupMenu.getMenu());\n\n            // Enable/disable draw and resign depending on gameOver\n            popupMenu.getMenu().findItem(R.id.action_draw).setEnabled(!gameOver);\n            popupMenu.getMenu().findItem(R.id.action_resign).setEnabled(!gameOver);\n\n            // Set click listener for menu items\n            popupMenu.setOnMenuItemClickListener(item -> {\n                //gets id of click\n                int id = item.getItemId();\n//checks which one matches and does the right function\n                if (awaitingPromotion) return true; // ignore clicks during promotion\n\n                // After game over  only restart is allowed\n                if (gameOver && id != R.id.action_restart) return true;\n\n                if (id == R.id.action_restart) {\n                    confirmRestart();\n                    return true;\n                }\n\n                if (id == R.id.action_draw) {\n                    offerDraw();\n                    return true;\n                }\n\n                if (id == R.id.action_resign) {\n                    confirmResign();\n                    return true;\n                }\n\n                return false;\n            });\n\n            popupMenu.show(); // finally show it\n        });\n\n\n    }\n//shortcut to get board\n    private Board board() {\n        return gameState.getBoard();\n    }\n//shortcut to get turn\n    private PieceColour currentTurn() {\n        return gameState.getCurrentTurn();\n    }\n\n\n    private void confirmRestart() {\n        //warning message\n        new AlertDialog.Builder(this)\n                .setTitle(\"Restart Game?\")\n                .setMessage(\"The current game will be lost.\")\n                .setPositiveButton(\"Restart\", (d, w) -> restartGame())\n                .setNegativeButton(\"Cancel\", null)\n                .show();\n    }\n\n    private void offerDraw() {\n        // Only allow if game is ongoing\n        if (gameOver || awaitingPromotion) return;\n//warning message\n        new AlertDialog.Builder(this)\n                .setTitle(\"Offer Draw\")\n                .setMessage(\"Do you want to offer a draw?\")\n                .setPositiveButton(\"Yes\", (d, w) -> {\n                    gameState.agreeDraw(); // call the GameState method\n                    handleGameOver();\n                })\n                .setNegativeButton(\"No\", null)\n                .show();\n    }\n\n    private void confirmResign() {\n        if (gameOver || awaitingPromotion) return;\n//checks turn to see who resigned\n        PieceColour resigningColour = gameState.getCurrentTurn();\n//warning message\n        new AlertDialog.Builder(this)\n                .setTitle(\"Resign?\")\n                .setMessage(resigningColour == PieceColour.WHITE\n                        ? \"White will resign the game.\"\n                        : \"Black will resign the game.\")\n                .setPositiveButton(\"Resign\", (d, w) -> {\n                    gameState.resign(resigningColour); // call GameState\n                    handleGameOver();\n                })\n                .setNegativeButton(\"Cancel\", null)\n                .show();\n    }\n\n\n\n    private void createChessBoard() {\n        GridLayout chessBoard = findViewById(R.id.chessBoard);\n\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n                //builds square and allows stacking\n                FrameLayout square = new FrameLayout(this);\n\n                GridLayout.LayoutParams params = new GridLayout.LayoutParams();\n                params.width = 0;\n                params.height = 0;\n                //keeps ratio\n                params.rowSpec = GridLayout.spec(row, 1f);\n                params.columnSpec = GridLayout.spec(col, 1f);\n\n                square.setLayoutParams(params);\n                //sets the colour even/odd\n                boolean isWhite = (row + col) % 2 == 0;\n                square.setBackgroundColor(\n                        isWhite\n                                ? Color.parseColor(\"#F0D9B5\")\n                                : Color.parseColor(\"#B58863\")\n                );\n// gives tags to connect UI to code\n                square.setTag(new SquareTag(row, col));\n                //triggers function onSquareClicked\n                square.setOnClickListener(this::onSquareClicked);\n\n                squareViews[row][col] = square;   //  store reference\n                chessBoard.addView(square);//adds them\n            }\n        }\n\n        renderBoard(); //  draw pieces\n    }\n    private void makeBoardSquare() {\n        GridLayout chessBoard = findViewById(R.id.chessBoard);\n        //keeps square shape\n        chessBoard.post(() -> {\n            int width = chessBoard.getWidth();\n\n            FrameLayout.LayoutParams params =\n                    (FrameLayout.LayoutParams) chessBoard.getLayoutParams();\n\n            params.height = width;   //  force square change\n            chessBoard.setLayoutParams(params);\n        });\n    }\n\n    private void renderBoard() {\n\n        clearAllHighlights();\n//cleans all pieces from last game\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n                squareViews[row][col].removeAllViews();\n            }\n        }\n        //places the pieces\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n//checks if a piece needs to go there\n                Piece piece = board().getPiece(new Position(col, row));\n                if (piece == null) continue;\n//places the right piece on the board\n                ImageView pieceView = new ImageView(this);\n                pieceView.setImageResource(getPieceDrawable(piece));\n                pieceView.setScaleType(ImageView.ScaleType.CENTER_INSIDE);\n                //adds piece\n                squareViews[row][col].addView(pieceView);\n            }\n        }\n    }\n\n    private int getPieceDrawable(Piece piece) {\n//returns the correct image back to the square according to colour\n        boolean white = piece.getColour() == PieceColour.WHITE;\n        //checks type of piece\n        switch (piece.getType()) {\n            case KING:\n                return white ? R.drawable.w_king : R.drawable.b_king;\n            case QUEEN:\n                return white ? R.drawable.w_queen : R.drawable.b_queen;\n            case ROOK:\n                return white ? R.drawable.w_rook : R.drawable.b_rook;\n            case BISHOP:\n                return white ? R.drawable.w_bishop : R.drawable.b_bishop;\n            case KNIGHT:\n                return white ? R.drawable.w_knight : R.drawable.b_knight;\n            case PAWN:\n                return white ? R.drawable.w_pawn : R.drawable.b_pawn;\n        }\n//safety\n        throw new IllegalStateException(\"Unknown piece type\");\n    }\n    //updates the score using the new score it gets UI\n    private void updateScoreUI() {\n        TextView tvWhiteScore = findViewById(R.id.tvWhiteScore);\n        TextView tvBlackScore = findViewById(R.id.tvBlackScore);\n\n        tvWhiteScore.setText(String.format(\" (%.1f)\", whiteScore));\n        tvBlackScore.setText(String.format(\" (%.1f)\", blackScore));\n\n    }\n    //adds 1 or 0.5 depending on result and updates the scores\n    private void updateScore(GameResult result) {\n        switch (result) {\n            case BLACK_RESIGNED:\n            case WHITE_CHECKMATE:\n            case TIMEOUT_BLACK:\n                whiteScore += 1.0;\n                break;\n\n            case BLACK_CHECKMATE:\n            case TIMEOUT_WHITE:\n            case WHITE_RESIGNED:\n                blackScore += 1.0;\n                break;\n\n            case STALEMATE:\n            case DRAW_AGREED:\n            case DRAW_THREEFOLD_REPETITION:\n            case DRAW_INSUFFICIENT_MATERIAL:\n                whiteScore += 0.5;\n                blackScore += 0.5;\n                break;\n        }\n    }\n\n//main function for handling  after click on square\n    private void onSquareClicked(View view) {\n        //filters clicks out of play\n        if (gameOver || awaitingPromotion) return;\n        //checks if piece is on square\n        SquareTag tag = (SquareTag) view.getTag();\n        Piece clickedPiece = board().getPiece(\n                new Position(tag.col, tag.row)\n        );\n\n        // 1️ No piece selected yet(opponent' / empty)\n        if (selectedSquare == null) {\n            if (clickedPiece == null) return;\n            if (clickedPiece.getColour() != currentTurn()) return;\n\n//visual update by marking square and possible moves\n            selectSquare(view);\n            showLegalMoves(tag);\n            return;\n        }\n\n        //  Same square → deselect\n        if (view == selectedSquare) {\n            clearSelection();\n            clearMoveHighlights();\n            currentLegalMoves.clear();\n            return;\n        }\n\n        //  Try execute move\n        Move move = getMoveTo(tag);\n\n        if (move != null) {\n            executeMove(move);\n        }\n\n        clearSelection();\n        clearMoveHighlights();\n        currentLegalMoves.clear();\n    }\n\n\n\n\n    private void selectSquare(View square) {\n        //clears last selection\n        clearSelection();\n\n        selectedSquare = square;\n        selectedTag = (SquareTag) square.getTag();\n\n        SquareTag tag = selectedTag;\n        boolean isWhiteSquare = (tag.row + tag.col) % 2 == 0;\n//according to colour of square it changes the highlight of the square\n        int baseColour = isWhiteSquare\n                ? Color.parseColor(\"#F0D9B5\")\n                : Color.parseColor(\"#B58863\");\n\n        int highlightColour = isWhiteSquare\n                ? Color.parseColor(\"#E0CFA5\")\n                : Color.parseColor(\"#9E7C4F\");\n\n        square.setBackgroundColor(highlightColour);\n    }\n\n\n\n    private void clearSelection() {\n        //resets colour on square if it was selected\n        if (selectedSquare != null && selectedTag != null) {\n//checks the right colour\n            boolean isWhiteSquare =\n                    (selectedTag.row + selectedTag.col) % 2 == 0;\n\n            selectedSquare.setBackgroundColor(\n                    isWhiteSquare\n                            ? Color.parseColor(\"#F0D9B5\")\n                            : Color.parseColor(\"#B58863\")\n            );\n//avoid bugs\n            selectedSquare = null;\n            selectedTag = null;\n        }\n    }\n\n\n\n//creates dots\n    private View createMoveDot() {\n        View dot = new View(this);\n        //defines it\n        int size = (int) (18 * getResources().getDisplayMetrics().density); // 18dp\n\n        FrameLayout.LayoutParams params =\n                new FrameLayout.LayoutParams(size, size);\n        params.gravity = android.view.Gravity.CENTER;\n//adds the dot\n        dot.setLayoutParams(params);\n        dot.setBackgroundResource(R.drawable.move_dot);\n\n        return dot;\n    }\n    //creates ring\n    private View createCaptureRing() {\n        View ring = new View(this);\n//defines it on top of the piece\n        FrameLayout.LayoutParams params =\n                new FrameLayout.LayoutParams(\n                        FrameLayout.LayoutParams.MATCH_PARENT,\n                        FrameLayout.LayoutParams.MATCH_PARENT\n                );\n        params.gravity = android.view.Gravity.CENTER;\n//adds it\n        ring.setLayoutParams(params);\n        ring.setBackgroundResource(R.drawable.capture_ring);\n\n        return ring;\n    }\n\n\n\n    private void clearMoveHighlights() {\n        for (View square : highlightedSquares) {\n            //remove dots\n            View dot = (View) square.getTag(R.id.move_dot);\n            if (dot != null) {\n                ((FrameLayout) square).removeView(dot);\n                square.setTag(R.id.move_dot, null);\n            }\n//remove rings\n            View ring = (View) square.getTag(R.id.capture_ring);\n            if (ring != null) {\n                ((FrameLayout) square).removeView(ring);\n                square.setTag(R.id.capture_ring, null);\n            }\n        }\n        highlightedSquares.clear();\n    }\n\n    //gets tag and marks legal moves\n    private void showLegalMoves(SquareTag fromTag) {\n//remove marks\n        clearMoveHighlights();\n\n        Position from = new Position(fromTag.col, fromTag.row);\n//gets all moves including pins\n        List<Move> pseudoMoves = MoveGenerator.generateMoves(board(), from);\n        currentLegalMoves.clear();\n//checks if moves put in check\n        for (Move move : pseudoMoves) {\n            if (MoveValidator.isLegalMove(board(), move, currentTurn())) {\n                currentLegalMoves.add(move);\n//verify position\n                int row = move.to.y;\n                int col = move.to.x;\n                View targetSquare = squareViews[row][col];\n                Piece targetPiece = board().getPiece(move.to);\n\n                if (targetPiece == null) {\n                    // Normal move → dot\n                    View dot = createMoveDot();\n                    targetSquare.setTag(R.id.move_dot, dot);\n                    ((FrameLayout) targetSquare).addView(dot);\n                    //if there is a targeted piece it puts a ring\n                } else {\n                    // Capture  ring\n                    View ring = createCaptureRing();\n                    targetSquare.setTag(R.id.capture_ring, ring);\n                    ((FrameLayout) targetSquare).addView(ring);\n                }\n//adds it to highlighted squares\n                highlightedSquares.add(targetSquare);\n\n            }\n        }\n    }\n\n//checks if the desired move is legal by comparing the legal moves list\n    // the square needs to be legal\n    private Move getMoveTo(SquareTag toTag) {\n\n        for (Move move : currentLegalMoves) {\n            if (move.to.x == toTag.col && move.to.y == toTag.row) {\n                //returns info about move\n                return move;\n            }\n        }\n        return null;\n    }\n\n    //executes the move\n    private void executeMove(Move move) {\n\n        // Try to make move via GameState make move rules\n        boolean moved = gameState.makeMove(move);\n        if (!moved) return;\n\n        // Check promotion AFTER move\n        Piece pieceAtDestination = board().getPiece(move.to);\n\n        if (pieceAtDestination != null &&\n                pieceAtDestination.getType() == PieceType.PAWN) {\n//finds correct y position\n            int promotionRow =\n                    (pieceAtDestination.getColour() == PieceColour.WHITE) ? 0 : 7;\n\n            if (move.to.y == promotionRow) {\n                awaitingPromotion = true;\n\n                // Pause timers\n                whiteTimer.cancel();\n                blackTimer.cancel();\n//shows promotion dialog\n                showPromotionDialog(move.to, pieceAtDestination.getColour());\n                return;\n            }\n        }\n\n        // Move is complete and calls next function\n        onMoveFinished();\n    }\n\n//shows promotion picks\n    private void showPromotionDialog(Position position, PieceColour colour) {\n\n        View view = getLayoutInflater().inflate(R.layout.dialog_promotion, null);\n\n        ImageView queen  = view.findViewById(R.id.promoQueen);\n        ImageView rook   = view.findViewById(R.id.promoRook);\n        ImageView bishop = view.findViewById(R.id.promoBishop);\n        ImageView knight = view.findViewById(R.id.promoKnight);\n\n        // Set correct icons based on colour\n        if (colour == PieceColour.WHITE) {\n            queen.setImageResource(R.drawable.w_queen);\n            rook.setImageResource(R.drawable.w_rook);\n            bishop.setImageResource(R.drawable.w_bishop);\n            knight.setImageResource(R.drawable.w_knight);\n        } else {\n            queen.setImageResource(R.drawable.b_queen);\n            rook.setImageResource(R.drawable.b_rook);\n            bishop.setImageResource(R.drawable.b_bishop);\n            knight.setImageResource(R.drawable.b_knight);\n        }\n//define dialog\n        androidx.appcompat.app.AlertDialog dialog =\n                new androidx.appcompat.app.AlertDialog.Builder(this)\n                        .setTitle(\"Promote pawn\")\n                        .setCancelable(false)\n                        .setView(view)\n                        .create();\n//calls promote function according to choice\n        queen.setOnClickListener(v ->\n                promote(position, PieceType.QUEEN, dialog));\n        rook.setOnClickListener(v ->\n                promote(position, PieceType.ROOK, dialog));\n        bishop.setOnClickListener(v ->\n                promote(position, PieceType.BISHOP, dialog));\n        knight.setOnClickListener(v ->\n                promote(position, PieceType.KNIGHT, dialog));\n\n        dialog.show();\n    }\n\n\n    private void promote(Position position,\n                         PieceType type,\n                         androidx.appcompat.app.AlertDialog dialog) {\n//gets pawn and has safety check\n        Piece pawn = board().getPiece(position);\n        if (pawn == null) return;\n//replaces piece\n        board().setPiece(position, new Piece(type, pawn.getColour()));\n//promotion done\n        dialog.dismiss();\n        awaitingPromotion = false;\n\n        onMoveFinished();\n    }\n\n    //final step of moves\n    private void onMoveFinished() {\n\n        clearAllHighlights();\n\n        stopTimers();\n//checks for game over\n        if (gameState.isGameOver()) {\n            handleGameOver();\n            renderBoard();\n            return;\n        }\n//start other player's clock\n        startTimerForCurrentTurn();\n//checks for highlight\n        showCheckIfNeeded();\n        renderBoard();\n    }\n\n    private void startTimerForCurrentTurn() {\n        if (gameOver) return;\n        //change clock colour\n        updateClockStyles();\n        createTimers(); // recreate using REMAINING time\n//start the correct clock\n        if (currentTurn() == PieceColour.WHITE) {\n            whiteTimer.start();\n        } else {\n            blackTimer.start();\n        }\n    }\n\n    private void stopTimers() {\n        //safety if and stops both times\n        if (whiteTimer != null) whiteTimer.cancel();\n        if (blackTimer != null) blackTimer.cancel();\n    }\n\n\n    private void showCheckIfNeeded() {\n\n        clearCheckHighlight();\n//checks check\n        if (!CheckDetector.isKingInCheck(board(), currentTurn())) return;\n//safety check\n        Position kingPos = board().findKing(currentTurn());\n        if (kingPos == null) return;\n//gets matching positons in view and set colour\n        View kingSquare = squareViews[kingPos.y][kingPos.x];\n        kingSquare.setForeground(\n                new ColorDrawable(Color.parseColor(\"#88FF0000\"))\n        );\n    }\n\n//resets for next game\n    private void restartGame() {\n        stopTimers();\n//change back colour from handle game over\n        GridLayout chessBoard = findViewById(R.id.chessBoard);\n        chessBoard.setAlpha(1f);\n        chessBoard.setEnabled(true);\n//change back  the function checks to false\n        gameState = new GameState();\n        gameOver = false;\n        awaitingPromotion = false;\n//resets clock\n        initClocks(gameTimeMinutes);\n        whiteTimer.start(); // White starts\n//clear the banner\n        gameOverBanner.setVisibility(View.GONE);\n//clear highlights and reset board\n        clearAllHighlights();\n        clearCheckHighlight();\n        updateClockStyles();\n        renderBoard();\n    }\n\n//main function that handles clearing ui highlights\n    private void clearAllHighlights() {\n        clearSelection();\n        clearMoveHighlights();\n    }\n    private void initClocks(int minutes) {\n//convert time to millisecond\n        whiteTimeMs = minutes * 60 * 1000L;\n        blackTimeMs = minutes * 60 * 1000L;\n\n        tvWhiteClock = findViewById(R.id.tvWhiteClock);\n        tvBlackClock = findViewById(R.id.tvBlackClock);\n//connect back the time\n        updateClockText(tvWhiteClock, whiteTimeMs);\n        updateClockText(tvBlackClock, blackTimeMs);\n\n        createTimers();\n    }\n    private void createTimers() {\n//white timer\n        whiteTimer = new CountDownTimer(whiteTimeMs, 1000) {\n            @Override\n            //every second\n            public void onTick(long millisUntilFinished) {\n                whiteTimeMs = millisUntilFinished;\n                updateClockText(tvWhiteClock, whiteTimeMs);\n            }\n\n            @Override\n            //checks when 0\n            public void onFinish() {\n                onTimeExpired(PieceColour.WHITE);\n            }\n        };\n//same just for black\n        blackTimer = new CountDownTimer(blackTimeMs, 1000) {\n            @Override\n            public void onTick(long millisUntilFinished) {\n                blackTimeMs = millisUntilFinished;\n                updateClockText(tvBlackClock, blackTimeMs);\n            }\n\n            @Override\n            public void onFinish() {\n                onTimeExpired(PieceColour.BLACK);\n            }\n        };\n    }\n//translates the timer into minutes and seconds\n    private void updateClockText(TextView tv, long timeMs) {\n        int seconds = (int) (timeMs / 1000);\n        int minutes = seconds / 60;\n        int remainingSeconds = seconds % 60;\n\n        tv.setText(String.format(\"%02d:%02d\", minutes, remainingSeconds));\n\n        //  Last 30 seconds warning\n        if (timeMs <= 30_000) {\n            tv.setTextColor(Color.RED);\n        } else {\n            tv.setTextColor(Color.BLACK);\n        }\n    }\n    //updates gamestate when a timer reaches 0\n    private void onTimeExpired(PieceColour loser) {\n        gameState.onTimeExpired(loser);\n        handleGameOver();\n    }\n    private void handleGameOver() {\n//gets result\n        GameResult result = gameState.getResult();\n\n        stopTimers();\n        //now UI ignores clicks\n        gameOver = true;\n//visual change to board\n        GridLayout chessBoard = findViewById(R.id.chessBoard);\n        chessBoard.setAlpha(0.5f);\n        chessBoard.setEnabled(false);\n// update leaderboard and score\n        updateScore(result);\n        updateLeaderboardPoints(result);\n//save the score\n        saveGameToHistory(result);\n\n        clearAllHighlights();\n//shows scores and banner\n        findViewById(R.id.tvWhiteScore).setVisibility(View.VISIBLE);\n        findViewById(R.id.tvBlackScore).setVisibility(View.VISIBLE);\n\n        updateScoreUI();\n        gameOverBanner.setVisibility(View.VISIBLE);\n\n\n//displays text depending on result\n        switch (result) {\n\n            case WHITE_RESIGNED:\n                tvGameOverMessage.setText(\"White resigned\");\n                break;\n\n            case BLACK_RESIGNED:\n                tvGameOverMessage.setText(\"Black resigned\");\n                break;\n\n            case DRAW_AGREED:\n                tvGameOverMessage.setText(\"Draw agreed\");\n                break;\n\n            case TIMEOUT_WHITE:\n                tvGameOverMessage.setText(\"Black wins on time\");\n                break;\n\n            case TIMEOUT_BLACK:\n                tvGameOverMessage.setText(\"White wins on time\");\n                break;\n\n            case WHITE_CHECKMATE:\n                tvGameOverMessage.setText(\"White wins by checkmate\");\n                break;\n\n            case BLACK_CHECKMATE:\n                tvGameOverMessage.setText(\"Black wins by checkmate\");\n                break;\n\n            case STALEMATE:\n                tvGameOverMessage.setText(\"Stalemate\");\n                break;\n\n            case DRAW_INSUFFICIENT_MATERIAL:\n                tvGameOverMessage.setText(\"Draw – insufficient material\");\n                break;\n\n            case DRAW_THREEFOLD_REPETITION:\n                tvGameOverMessage.setText(\"Draw – threefold repetition\");\n                break;\n\n            case DRAW_FIFTY_MOVE_RULE:\n                tvGameOverMessage.setText(\"Draw – 50-move rule\");\n                break;\n        }\n\n    }\n    private void updateClockStyles() {\n        //sets colours according to the turn\n        if (gameState.getCurrentTurn() == PieceColour.WHITE) {\n            // White's turn\n            setActiveClock(tvWhiteClock);\n            setInactiveClock(tvBlackClock);\n        } else {\n            // Black's turn\n            setActiveClock(tvBlackClock);\n            setInactiveClock(tvWhiteClock);\n        }\n    }\n    //updates point system\n    private void updateLeaderboardPoints(GameResult result) {\n\n        double whitePoints = 0;\n        double blackPoints = 0;\n//sets points according to result\n        switch (result) {\n\n            case WHITE_CHECKMATE:\n            case TIMEOUT_BLACK:\n            case BLACK_RESIGNED:\n                whitePoints = 1;\n                break;\n\n            case BLACK_CHECKMATE:\n            case TIMEOUT_WHITE:\n            case WHITE_RESIGNED:\n                blackPoints = 1;\n                break;\n\n            case STALEMATE:\n            case DRAW_AGREED:\n            case DRAW_THREEFOLD_REPETITION:\n            case DRAW_INSUFFICIENT_MATERIAL:\n            case DRAW_FIFTY_MOVE_RULE:\n                whitePoints = 0.5;\n                blackPoints = 0.5;\n                break;\n        }\n//adds to leaderboard\n        LeaderboardManager.addPoints(this, whitePlayerName, whitePoints);\n        LeaderboardManager.addPoints(this, blackPlayerName, blackPoints);\n    }\n\n//set colour for active watch\n    private void setActiveClock(TextView clock) {\n        clock.setBackgroundColor(Color.WHITE);\n        clock.setTextColor(Color.BLACK);\n    }\n    //set colour for inactive watch\n    private void setInactiveClock(TextView clock) {\n        clock.setBackgroundColor(Color.parseColor(\"#222222\"));\n        clock.setTextColor(Color.WHITE);\n    }\n    private void clearCheckHighlight() {\n        for (int row = 0; row < 8; row++) {\n            for (int col = 0; col < 8; col++) {\n                squareViews[row][col].setForeground(null);\n            }\n        }\n    }\n    //returns the  score string according to the result\n    private String getResultString(GameResult result) {\n        switch (result) {\n            case BLACK_RESIGNED:\n            case WHITE_CHECKMATE:\n            case TIMEOUT_BLACK:\n                return \"1-0\";\n\n            case BLACK_CHECKMATE:\n            case WHITE_RESIGNED:\n            case TIMEOUT_WHITE:\n                return \"0-1\";\n\n            case STALEMATE:\n            case DRAW_AGREED:\n            case DRAW_THREEFOLD_REPETITION:\n            case DRAW_INSUFFICIENT_MATERIAL:\n            case DRAW_FIFTY_MOVE_RULE:\n                return \"½-½\";\n        }\n        //no result\n        return \"*\";\n    }\n    //returns the colour that won or draw string\n    private String getWinnerString(GameResult result) {\n        switch (result) {\n            case WHITE_CHECKMATE:\n            case TIMEOUT_BLACK:\n            case BLACK_RESIGNED:\n                return \"White won\";\n\n            case BLACK_CHECKMATE:\n            case WHITE_RESIGNED:\n            case TIMEOUT_WHITE:\n                return \"Black won\";\n\n            default:\n                return \"Draw\";\n        }\n    }\n\n\n\n\n    private void saveGameToHistory(GameResult result) {\n//creates object\n        GameHistoryDatabase db = new GameHistoryDatabase(this);\n        //adds names scores and winner\n        GameHistory game = new GameHistory(\n                0L, //\n                whitePlayerName,\n                blackPlayerName,\n                getResultString(result),\n                getWinnerString(result)\n        );\n\n//adds it to the database\n        db.insertGame(game);\n    }\n\n\n\n\n","internalCalls":[{"from":{"v":"#","ret":"void","n":"onCreate","p":"savedInstanceState","ctor":false,"body":"\n        //opens screen\n        super.onCreate(savedInstanceState);\n        setContentView(R.layout.activity_main);\n\n        gameOverBanner = findViewById(R.id.gameOverBanner);\n        tvGameOverMessage = findViewById(R.id.tvGameOverMessage);\n\n        // Window insets( adjusts the screen)\n        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main), (v, insets) -> {\n            Insets systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars());\n            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom);\n            return insets;\n        });\n\n        // Game logic object\n        gameState = new GameState();\n\n        //  Read intent ONCE\n        Intent intent = getIntent();\n        whitePlayerName = intent.getStringExtra(\"PLAYER_WHITE\");\n        blackPlayerName = intent.getStringExtra(\"PLAYER_BLACK\");\n        gameTimeMinutes = intent.getIntExtra(\"GAME_TIME\", 0);\n\n        boolean isFirstGame = intent.getBooleanExtra(\"IS_FIRST_GAME\", true);\n        whiteScore = intent.getDoubleExtra(\"WHITE_SCORE\", 0);\n        blackScore = intent.getDoubleExtra(\"BLACK_SCORE\", 0);\n\n        //  Set player names\n        TextView tvWhite = findViewById(R.id.tvPlayerWhite);\n        TextView tvBlack = findViewById(R.id.tvPlayerBlack);\n        tvWhite.setText(\"White: \" + whitePlayerName);\n        tvBlack.setText(\"Black: \" + blackPlayerName);\n\n        //  Score UI (ONLY from second game)\n        TextView tvWhiteScore = findViewById(R.id.tvWhiteScore);\n        TextView tvBlackScore = findViewById(R.id.tvBlackScore);\n\n// doesn't show score on first game\n        if (isFirstGame) {\n            tvWhiteScore.setVisibility(View.GONE);\n            tvBlackScore.setVisibility(View.GONE);\n        } else {\n            tvWhiteScore.setVisibility(View.VISIBLE);\n            tvBlackScore.setVisibility(View.VISIBLE);\n            updateScoreUI();\n        }\n\n\n        //  Init clocks\n        initClocks(gameTimeMinutes);\n        whiteTimer.start(); // White starts\n\n        //  Build board\n        createChessBoard();\n        makeBoardSquare();\n\n        // Leave button endscreen\n        Button btnLeave = findViewById(R.id.btnLeave);\n        btnLeave.setOnClickListener(v -> {\n            Intent leaveIntent = new Intent(MainActivity.this, StartActivity.class);\n            leaveIntent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_NEW_TASK);\n            startActivity(leaveIntent);\n            finish();\n        });\n\n        // New Game button endscreen\n        Button btnNewGame = findViewById(R.id.btnNewGame);\n        btnNewGame.setOnClickListener(v -> {\n            Intent newGameIntent = new Intent(MainActivity.this, MainActivity.class);\n\n            newGameIntent.putExtra(\"PLAYER_WHITE\", whitePlayerName);\n            newGameIntent.putExtra(\"PLAYER_BLACK\", blackPlayerName);\n            newGameIntent.putExtra(\"GAME_TIME\", gameTimeMinutes);\n\n            newGameIntent.putExtra(\"WHITE_SCORE\", whiteScore);\n            newGameIntent.putExtra(\"BLACK_SCORE\", blackScore);\n            newGameIntent.putExtra(\"IS_FIRST_GAME\", false);\n            startActivity(newGameIntent);\n            finish();\n        });\n\n        ImageButton menuButton = findViewById(R.id.menuButton);\n\n        menuButton.setOnClickListener(v -> {\n            // Create popup menu here\n            PopupMenu popupMenu = new PopupMenu(this, v);\n            popupMenu.getMenuInflater().inflate(R.menu.menu, popupMenu.getMenu());\n\n            // Enable/disable draw and resign depending on gameOver\n            popupMenu.getMenu().findItem(R.id.action_draw).setEnabled(!gameOver);\n            popupMenu.getMenu().findItem(R.id.action_resign).setEnabled(!gameOver);\n\n            // Set click listener for menu items\n            popupMenu.setOnMenuItemClickListener(item -> {\n                //gets id of click\n                int id = item.getItemId();\n//checks which one matches and does the right function\n                if (awaitingPromotion) return true; // ignore clicks during promotion\n\n                // After game over  only restart is allowed\n                if (gameOver && id != R.id.action_restart) return true;\n\n                if (id == R.id.action_restart) {\n                    confirmRestart();\n                    return true;\n                }\n\n                if (id == R.id.action_draw) {\n                    offerDraw();\n                    return true;\n                }\n\n                if (id == R.id.action_resign) {\n                    confirmResign();\n                    return true;\n                }\n\n                return false;\n            });\n\n            popupMenu.show(); // finally show it\n        });\n\n\n    ","comment":""},"to":{"v":"-","ret":"void","n":"confirmRestart","p":"","ctor":false,"body":"\n        //warning message\n        new AlertDialog.Builder(this)\n                .setTitle(\"Restart Game?\")\n                .setMessage(\"The current game will be lost.\")\n                .setPositiveButton(\"Restart\", (d, w) -> restartGame())\n                .setNegativeButton(\"Cancel\", null)\n                .show();\n    ","comment":""}},{"from":{"v":"#","ret":"void","n":"onCreate","p":"savedInstanceState","ctor":false,"body":"\n        //opens screen\n        super.onCreate(savedInstanceState);\n        setContentView(R.layout.activity_main);\n\n        gameOverBanner = findViewById(R.id.gameOverBanner);\n        tvGameOverMessage = findViewById(R.id.tvGameOverMessage);\n\n        // Window insets( adjusts the screen)\n        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main), (v, insets) -> {\n            Insets systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars());\n            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom);\n            return insets;\n        });\n\n        // Game logic object\n        gameState = new GameState();\n\n        //  Read intent ONCE\n        Intent intent = getIntent();\n        whitePlayerName = intent.getStringExtra(\"PLAYER_WHITE\");\n        blackPlayerName = intent.getStringExtra(\"PLAYER_BLACK\");\n        gameTimeMinutes = intent.getIntExtra(\"GAME_TIME\", 0);\n\n        boolean isFirstGame = intent.getBooleanExtra(\"IS_FIRST_GAME\", true);\n        whiteScore = intent.getDoubleExtra(\"WHITE_SCORE\", 0);\n        blackScore = intent.getDoubleExtra(\"BLACK_SCORE\", 0);\n\n        //  Set player names\n        TextView tvWhite = findViewById(R.id.tvPlayerWhite);\n        TextView tvBlack = findViewById(R.id.tvPlayerBlack);\n        tvWhite.setText(\"White: \" + whitePlayerName);\n        tvBlack.setText(\"Black: \" + blackPlayerName);\n\n        //  Score UI (ONLY from second game)\n        TextView tvWhiteScore = findViewById(R.id.tvWhiteScore);\n        TextView tvBlackScore = findViewById(R.id.tvBlackScore);\n\n// doesn't show score on first game\n        if (isFirstGame) {\n            