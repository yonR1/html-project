.blackKingSideCastle;\r\n        copy.blackQueenSideCastle = this.blackQueenSideCastle;\r\n\r\n        // DEEP COPY lastMove\r\n        if (this.lastMove != null) {\r\n            copy.lastMove = new Move(\r\n                    new Position(this.lastMove.from.x, this.lastMove.from.y),\r\n                    new Position(this.lastMove.to.x, this.lastMove.to.y),\r\n                    this.lastMove.promotion\r\n            );\r\n        } else {\r\n            copy.lastMove = null;\r\n        }\r\n\r\n        return copy;\r\n    ","comment":""},{"v":"+","ret":"boolean","n":"canCastleKingSide","p":"colour","ctor":false,"body":"\r\n        return colour == PieceColour.WHITE\r\n                ? whiteKingSideCastle\r\n                : blackKingSideCastle;\r\n    ","comment":""},{"v":"+","ret":"boolean","n":"canCastleQueenSide","p":"colour","ctor":false,"body":"\r\n        return colour == PieceColour.WHITE\r\n                ? whiteQueenSideCastle\r\n                : blackQueenSideCastle;\r\n    ","comment":""},{"v":"+","ret":"Position","n":"findKing","p":"colour","ctor":false,"body":"\r\n        for (int y = 0; y < 8; y++) {\r\n            for (int x = 0; x < 8; x++) {\r\n                Piece p = board[y][x];\r\n                if (p != null &&\r\n                        p.getType() == PieceType.KING &&\r\n                        p.getColour() == colour) {\r\n                    return new Position(x, y);\r\n                }\r\n            }\r\n        }\r\n        return null;\r\n    ","comment":""},{"v":"+","ret":"String","n":"getPositionKey","p":"sideToMove","ctor":false,"body":"\r\n        StringBuilder sb = new StringBuilder();\r\n\r\n        // builds a string of dots(empty), W and B to write the pieces position\r\n        for (int y = 0; y < 8; y++) {\r\n            for (int x = 0; x < 8; x++) {\r\n                Piece p = board[y][x];\r\n                if (p == null) {\r\n                    sb.append(\".\");\r\n                } else {\r\n                    sb.append(p.getColour() == PieceColour.WHITE ? \"W\" : \"B\");\r\n                    sb.append(p.getType().ordinal());\r\n                }\r\n            }\r\n        }\r\n        //adds the turn\r\n        sb.append(sideToMove == PieceColour.WHITE ? \"W\" : \"B\");\r\n\r\n        // adds Castling rights\r\n        sb.append(whiteKingSideCastle ? \"K\" : \"-\");\r\n        sb.append(whiteQueenSideCastle ? \"Q\" : \"-\");\r\n        sb.append(blackKingSideCastle ? \"k\" : \"-\");\r\n        sb.append(blackQueenSideCastle ? \"q\" : \"-\");\r\n\r\n        // adds En passant availability\r\n        if (lastMove != null) {\r\n            Piece moved = getPiece(lastMove.to);\r\n            if (moved != null &&\r\n                    moved.getType() == PieceType.PAWN &&\r\n                    Math.abs(lastMove.from.y - lastMove.to.y) == 2) {\r\n\r\n                sb.append(\"EP\");\r\n                sb.append(lastMove.to.x);\r\n            } else {\r\n                sb.append(\"EP-\");\r\n            }\r\n        } else {\r\n            sb.append(\"EP-\");\r\n        }\r\n\r\n        return sb.toString();\r\n    ","comment":""}],"comment":"","rawBody":"\r\n    private boolean whiteKingSideCastle;\r\n    private boolean whiteQueenSideCastle;\r\n    private boolean blackKingSideCastle;\r\n    private boolean blackQueenSideCastle;\r\n\r\n\r\n    private final Piece[][] board;\r\n    private Move lastMove;\r\n\r\n    public Move getLastMove() {\r\n        return lastMove;\r\n    }\r\n\r\n\r\n    public Board() {\r\n        //it will hold the x y of the piece / describe the position\r\n        board = new Piece[8][8];\r\n        //places piece x y\r\n        initialise();\r\n//defines castling rights\r\n        whiteKingSideCastle = true;\r\n        whiteQueenSideCastle = true;\r\n        blackKingSideCastle = true;\r\n        blackQueenSideCastle = true;\r\n    }\r\n\r\n//fills up the board with the coordinates\r\n    private void initialise() {\r\n        // Pawns\r\n        for (int x = 0; x < 8; x++) {\r\n            board[1][x] = new Piece(PieceType.PAWN, PieceColour.BLACK);\r\n            board[6][x] = new Piece(PieceType.PAWN, PieceColour.WHITE);\r\n        }\r\n\r\n        // Rooks\r\n        board[0][0] = new Piece(PieceType.ROOK, PieceColour.BLACK);\r\n        board[0][7] = new Piece(PieceType.ROOK, PieceColour.BLACK);\r\n        board[7][0] = new Piece(PieceType.ROOK, PieceColour.WHITE);\r\n        board[7][7] = new Piece(PieceType.ROOK, PieceColour.WHITE);\r\n\r\n        // Knights\r\n        board[0][1] = new Piece(PieceType.KNIGHT, PieceColour.BLACK);\r\n        board[0][6] = new Piece(PieceType.KNIGHT, PieceColour.BLACK);\r\n        board[7][1] = new Piece(PieceType.KNIGHT, PieceColour.WHITE);\r\n        board[7][6] = new Piece(PieceType.KNIGHT, PieceColour.WHITE);\r\n\r\n        // Bishops\r\n        board[0][2] = new Piece(PieceType.BISHOP, PieceColour.BLACK);\r\n        board[0][5] = new Piece(PieceType.BISHOP, PieceColour.BLACK);\r\n        board[7][2] = new Piece(PieceType.BISHOP, PieceColour.WHITE);\r\n        board[7][5] = new Piece(PieceType.BISHOP, PieceColour.WHITE);\r\n\r\n        // Queens\r\n        board[0][3] = new Piece(PieceType.QUEEN, PieceColour.BLACK);\r\n        board[7][3] = new Piece(PieceType.QUEEN, PieceColour.WHITE);\r\n\r\n        // Kings\r\n        board[0][4] = new Piece(PieceType.KING, PieceColour.BLACK);\r\n        board[7][4] = new Piece(PieceType.KING, PieceColour.WHITE);\r\n    }\r\n    //returns position if legal\r\n    public Piece getPiece(Position position) {\r\n        if (!position.isValid()) return null;\r\n        return board[position.y][position.x];\r\n    }\r\n//changes position of piece on array\r\n    public void setPiece(Position position, Piece piece) {\r\n        if (!position.isValid()) return;\r\n        board[position.y][position.x] = piece;\r\n    }\r\n//handles the piece moving\r\n    public void movePiece(Move move) {\r\n        //saves the current position and the place it wants to move\r\n        Position from = move.from;\r\n        Position to = move.to;\r\n//returns positon and checks if valid\r\n        Piece piece = getPiece(from);\r\n        if (piece == null) return;\r\n\r\n        // ───── En passant capture ─────\r\n        //checks if its diagonal and empty\r\n        if (piece.getType() == PieceType.PAWN &&\r\n                from.x != to.x &&\r\n                getPiece(to) == null) {\r\n//checks position according to colour\r\n            int capturedY =\r\n                    (piece.getColour() == PieceColour.WHITE)\r\n                            ? to.y + 1\r\n                            : to.y - 1;\r\n//sets right positon and removes other pawn\r\n            Position capturedPawnPos = new Position(to.x, capturedY);\r\n            setPiece(capturedPawnPos, null);\r\n        }\r\n\r\n        // Capture rook → lose castling right\r\n        Piece captured = getPiece(to);\r\n        if (captured != null && captured.getType() == PieceType.ROOK) {\r\n            disableRookCastlingIfNeeded(to, captured.getColour());\r\n        }\r\n\r\n        // King move → lose castling\r\n        if (piece.getType() == PieceType.KING) {\r\n            disableKingCastling(piece.getColour());\r\n        }\r\n\r\n        // Rook move → lose castling side\r\n        if (piece.getType() == PieceType.ROOK) {\r\n            disableRookCastlingIfNeeded(from, piece.getColour());\r\n        }\r\n\r\n        // ───── Castling rook movement ─────\r\n        if (piece.getType() == PieceType.KING && Math.abs(to.x - from.x) == 2) {\r\n\r\n            int row = from.y;\r\n\r\n            if (to.x == 6) { // kingside\r\n                movePieceRaw(new Position(7, row), new Position(5, row));\r\n            } else if (to.x == 2) { // queenside\r\n                movePieceRaw(new Position(0, row), new Position(3, row));\r\n            }\r\n        }\r\n        movePieceRaw(from, to);\r\n        piece.setHasMoved(true);\r\n        lastMove = move;\r\n    }\r\n    private void movePieceRaw(Position from, Position to) {\r\n        // moves piece from to\r\n        setPiece(to, getPiece(from));\r\n        //sets from to null\r\n        setPiece(from, null);\r\n    }\r\n\r\n//helper function to quickly disable castling\r\n    private void disableKingCastling(PieceColour colour) {\r\n        if (colour == PieceColour.WHITE) {\r\n            whiteKingSideCastle = false;\r\n            whiteQueenSideCastle = false;\r\n        } else {\r\n            blackKingSideCastle = false;\r\n            blackQueenSideCastle = false;\r\n        }\r\n    }\r\n    //checks if the rook was on the starting positon(moved from there) and thus disable castling\r\n    private void disableRookCastlingIfNeeded(Position pos, PieceColour colour) {\r\n        if (colour == PieceColour.WHITE) {\r\n            if (pos.y == 7 && pos.x == 0) whiteQueenSideCastle = false;\r\n            if (pos.y == 7 && pos.x == 7) whiteKingSideCastle = false;\r\n        } else {\r\n            if (pos.y == 0 && pos.x == 0) blackQueenSideCastle = false;\r\n            if (pos.y == 0 && pos.x == 7) blackKingSideCastle = false;\r\n        }\r\n    }\r\n\r\n\r\n    public Board copy() {\r\n        Board copy = new Board();\r\n\r\n        // Clear auto-initialized board\r\n        for (int y = 0; y < 8; y++) {\r\n            for (int x = 0; x < 8; x++) {\r\n                copy.board[y][x] = null;\r\n            }\r\n        }\r\n\r\n        // Deep copy pieces from og board\r\n        for (int y = 0; y < 8; y++) {\r\n            for (int x = 0; x < 8; x++) {\r\n\r\n                Piece piece = this.board[y][x];\r\n\r\n                if (piece != null) {\r\n                    Piece cloned = new Piece(\r\n                            piece.getType(),\r\n                            piece.getColour()\r\n                    );\r\n                    cloned.setHasMoved(piece.hasMoved());\r\n                    copy.board[y][x] = cloned;\r\n                }\r